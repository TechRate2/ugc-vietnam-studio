{
  "components": {
    "schemas": {
      "Input": {
        "properties": {
          "model": {
            "type": "string",
            "description": "model name",
            "default": "z-image/turbo"
          },
          "prompt": {
            "description": "The positive prompt for the generation.",
            "type": "string"
          },
          "prompt_extend": {
            "default": false,
            "description": "Supports intelligent prompt rewriting for better results.",
            "type": "boolean"
          },
          "seed": {
            "default": -1,
            "description": "The random seed to use for the generation. -1 means a random seed will be used.",
            "type": "integer"
          },
          "size": {
            "default": "1024*1536",
            "maximum": 2048,
            "minimum": 512,
            "description": "The size of the generated media in pixels (width*height).",
            "type": "string"
          },
          "enable_base64_output": {
            "default": false,
            "description": "If enabled, the output will be encoded into a BASE64 string instead of a URL. This property is only available through the API.",
            "disabled": true,
            "type": "boolean"
          },
          "enable_sync_mode": {
            "default": false,
            "description": "If set to true, the function will wait for the result to be generated and uploaded before returning the response. It allows you to get the result directly in the response. This property is only available through the API.",
            "disabled": true,
            "type": "boolean"
          }
        },
        "required": [
          "model",
          "prompt"
        ],
        "type": "object",
        "x-order-properties": [
