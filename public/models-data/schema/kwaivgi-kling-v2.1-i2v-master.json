{
  "info": {
    "title": "AtlasCloud API",
    "version": "1.0.0",
    "description": "The AtlasCloud API."
  },
  "paths": {
    "/api/v1/model/generateVideo": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictionResponse"
                }
              }
            },
            "description": "The request status."
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Input"
              }
            }
          },
          "required": true
        }
      },
      "x-api-name": "model_run"
    },
    "/api/v1/model/result/{request_id}": {
      "get": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PredictionResponse"
                }
              }
            },
            "description": "Result of the request."
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "request_id",
            "schema": {
              "type": "string",
              "description": "Request ID"
            },
            "required": true
          }
        ]
      },
      "x-api-name": "model_result"
    }
  },
  "openapi": "3.0.0",
  "servers": [
    {
      "url": "https://api.atlascloud.ai"
    }
  ],
  "components": {
    "schemas": {
      "Input": {
        "type": "object",
        "required": [
          "model",
          "prompt",
          "image"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "model name",
            "default": "kwaivgi/kling-v2.1-i2v-master"
          },
          "image": {
            "type": "string",
            "default": "https://static.atlascloud.ai/media/images/1749522950129341275_kHvrnkgd.jpeg",
            "description": "First frame of the video; Supported image formats include.jpg/.jpeg/.png; The image file size cannot exceed 10MB, and the image resolution should not be less than 300*300px."
          },
          "prompt": {
            "type": "string",
            "default": "The scene opens with a small fishing boat caught in the midst of a raging storm. The sky is dark and ominous, filled with swirling clouds and flashes of lightning. The sea is tumultuous, with massive waves crashing against the boat, threatening to capsize it. The boat's deck is slick with rain, and the crew members are struggling to maintain control.",
            "maxLength": 2000,
            "description": "Text prompt for generation; Positive text prompt; Cannot exceed 2500 characters."
          },
          "duration": {
            "enum": [
              "5",
              "10"
            ],
            "step": 5,
            "type": "string",
            "default": "5",
            "description": "The duration of the generated media in seconds.",
            "x-ui-component": "select"
          },
          "guidance_scale": {
            "step": 0.01,
            "type": "number",
            "default": 0.5,
            "maximum": 1,
            "minimum": 0,
            "description": "The guidance scale to use for the generation."
          },
          "negative_prompt": {
            "type": "string",
            "default": "blur, distort, and low quality",
            "maxLength": 2500,
            "description": "Negative text prompt; Cannot exceed 2500 characters."
          }
        },
        "x-order-properties": [
          "model",
          "prompt",
          "negative_prompt",
          "image",
          "guidance_scale",
          "duration"
        ]
      },
      "PredictionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the prediction, the ID of the prediction to get."
          },
          "urls": {
            "type": "object",
            "description": "Object containing related API endpoints."
          },
          "model": {
            "type": "string",
            "description": "Model ID used for the prediction."
          },
          "status": {
            "type": "string",
            "description": "Status of the task: created, processing, completed, or failed."
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of URLs to the generated content (empty when status is not completed)."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO timestamp of when the request was created (e.g., “2023-04-01T12:34:56.789Z”)."
          },
          "has_nsfw_contents": {
            "type": "array",
            "items": {
              "type": "boolean"
            },
            "description": "Array of boolean values indicating NSFW detection for each output."
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "in": "header",
        "name": "Authorization",
        "type": "apiKey"
      }
    }
  }
}