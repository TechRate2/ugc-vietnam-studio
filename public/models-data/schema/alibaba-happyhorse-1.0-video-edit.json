{
    "info": {
        "title": "AtlasCloud API",
        "version": "1.0.0",
        "description": "The AtlasCloud API."
    },
    "openapi": "3.0.0",
    "paths": {
        "/api/v1/model/generateImage": {
            "post": {
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Input"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PredictionResponse"
                                }
                            }
                        },
                        "description": "The request status."
                    }
                }
            },
            "x-api-name": "model_run"
        },
        "/api/v1/model/prediction/{request_id}": {
            "get": {
                "parameters": [
                    {
                        "in": "path",
                        "name": "request_id",
                        "required": true,
                        "schema": {
                            "description": "Request ID",
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PredictionResponse"
                                }
                            }
                        },
                        "description": "Result of the request."
                    }
                }
            },
            "x-api-name": "model_result"
        }
    },
    "components": {
        "schemas": {
            "Input": {
                "type": "object",
                "properties": {
                    "model": {
                        "type": "string",
                        "description": "Model name.",
                        "default": "alibaba/happyhorse-1.0/video-edit",
                        "enum": [
                            "alibaba/happyhorse-1.0/video-edit"
                        ]
                    },
                    "video": {
                        "description": "URL of the video to edit. Supported formats are MP4 and MOV. Duration must be 3 to 60 seconds; videos longer than 15 seconds are processed from the beginning up to 15 seconds. Maximum file size is 100 MB.",
                        "type": "string"
                    },
                    "prompt": {
                        "description": "Text instruction describing the desired edit. Maximum length is 2500 characters.",
                        "type": "string"
                    },
                    "images": {
                        "description": "Optional reference image URLs. Provide up to 5 images. Supported formats are JPEG, JPG, PNG, BMP, and WEBP. Each image can be up to 10 MB and should have an aspect ratio between 1:2.5 and 2.5:1.",
                        "type": "array",
                        "maxItems": 5,
                        "items": {
                            "type": "string"
                        }
                    },
                    "resolution": {
                        "default": "1080P",
                        "description": "Output video resolution.",
                        "enum": [
                            "720P",
                            "1080P"
                        ],
                        "type": "string"
                    },
                    "audio_setting": {
                        "default": "auto",
                        "description": "Sound control mode.",
                        "enum": [
                            "auto",
                            "origin"
                        ],
                        "type": "string"
                    },
                    "seed": {
                        "default": -1,
                        "minimum": -1,
                        "maximum": 2147483647,
                        "description": "Random seed for video generation. Use -1 for a random seed.",
                        "type": "integer"
                    }
                },
                "required": [
                    "model",
                    "video",
                    "prompt"
                ],
                "x-order-properties": [
                    "model",
                    "video",
                    "prompt",
                    "images",
                    "resolution",
                    "audio_setting",
                    "seed"
                ]
            },
            "PredictionResponse": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "$ref": "#/components/schemas/PredictionData"
                    }
                }
            },
            "PredictionData": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique ID of the generation task."
                    },
                    "model": {
                        "type": "string",
                        "description": "Model used for the generation."
                    },
                    "outputs": {
                        "type": "array",
                        "description": "Generated video results. Each item is a video URL.",
                        "items": {
                            "type": "string"
                        }
                    },
                    "urls": {
                        "type": "object",
                        "properties": {
                            "get": {
                                "type": "string"
                            }
                        }
                    },
                    "status": {
                        "type": "string",
                        "description": "Current task status, such as created, processing, completed, unknown, or failed."
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "error": {
                        "type": "string",
                        "description": "Error message returned when the task fails."
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://api.atlascloud.ai"
        }
    ]
}