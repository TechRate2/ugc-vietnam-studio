# ====================================
# UGC VIETNAM — UNIFIED ENV TEMPLATE
# Copy file này thành .env.local (Next.js đọc tự động)
# Backend FastAPI cũng đọc cùng file qua pydantic-settings
# ====================================

# ===== FRONTEND → BACKEND =====
BACKEND_URL=http://localhost:8000

# ===== AI / LLM (Claude Anthropic) =====
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# ===== AtlasCloud (Image + Video) =====
# Docs: https://www.atlascloud.ai/docs
# Base URL chuẩn /api/v1 — KHÔNG chỉ /v1
ATLASCLOUD_API_KEY=xxxxxxxxxxxxxxxxxxxxx
ATLASCLOUD_BASE_URL=https://api.atlascloud.ai/api/v1

# ===== TTS (Text-to-Speech VN) =====
# Primary provider: GenMax (aggregator ElevenLabs + MiniMax)
TTS_PROVIDER=genmax

# ===== GenMax TTS (PRIMARY — only active TTS provider) =====
# Docs: https://genmax.io/app/api-docs
# Auth dùng header `xi-api-key` (KHÔNG phải Bearer)
# Aggregator ElevenLabs + MiniMax — chọn qua GENMAX_DEFAULT_PROVIDER
GENMAX_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxx
GENMAX_BASE_URL=https://api.genmax.io
# 6 voice VN ElevenLabs sẵn: Mai/Ngân/Trân (nữ) + Đức Huy/Ninh Đôn/Quân (nam)
# + 6 voice MiniMax budget tier (Tú Anh, Ngọc Huyền, Anh Khôi, Nghị Lực, Vui Vẻ, Phật Pháp)
GENMAX_DEFAULT_PROVIDER=elevenlabs
GENMAX_DEFAULT_VOICE_ID=d5HVupAWCwe4e6GvMCAL

# NOTE: VBee removed — chỉ dùng GenMax (cover cả 12 voice qua aggregator).
# Nếu cần tái add VBee fallback, restore VBEE_* env vars + tạo vendors/vbee.py client.

# ===== ElevenLabs (SFX cho ASMR mode) =====
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ===== Cloudflare R2 Storage =====
R2_ACCOUNT_ID=xxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxx
R2_BUCKET_NAME=ugc-vietnam-output
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# ===== Database =====
DATABASE_URL=postgresql://postgres:mypass@localhost:5432/ugc_vn

# ===== Redis Queue =====
REDIS_URL=redis://localhost:6379/0

# ===== Casso VietQR (Payment) =====
CASSO_API_KEY=AK_xxxxxxxxxxxxxxx
CASSO_WEBHOOK_SECRET=xxxxxxxxxxxxxxx

# ===== App =====
APP_ENV=development
APP_PORT=8000
WORKER_CONCURRENCY=4

# ===== Rate limits =====
RATE_LIMIT_FREE_TIER=2_per_day
RATE_LIMIT_STARTER=10_per_month
RATE_LIMIT_PRO=30_per_month
RATE_LIMIT_BUSINESS=80_per_month
